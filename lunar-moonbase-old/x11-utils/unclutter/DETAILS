           MODULE=unclutter
         VERSION=1.4
          SOURCE=$MODULE-$VERSION.tar.gz
SOURCE_DIRECTORY=$BUILD_DIRECTORY/$MODULE
      SOURCE_URL=http://www.ibiblio.org/pub/X11/contrib/utilities/
      SOURCE_VFY=shas256:
        WEB_SITE=http://www.ibiblio.org
         ENTERED=20010924
         UPDATED=20181211
           SHORT="unclutter: a program to hide the cursor in X"

cat << EOF
unclutter senses when the mouse hasn't been moved or a button clicked.
It then makes the cursor invisible until you move it again.  This is
used with some window managers that are keyboard controled.
EOF
