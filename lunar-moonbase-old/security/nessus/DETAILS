          MODULE=nessus
         VERSION=8.10.1
          SOURCE=nessus-libraries-$VERSION.tar.gz
         SOURCE2=libnasl-$VERSION.tar.gz
         SOURCE3=nessus-core-$VERSION.tar.gz
         SOURCE4=nessus-plugins-GPL-$VERSION.tar.gz
      SOURCE_VFY=sha256:
     SOURCE2_VFY=sha256:
     SOURCE3_VFY=sha256:
     SOURCE4_VFY=sha256:
   SOURCE_URL[0]=ftp://ftp.intevation.de/boss/src/$MODULE
  SOURCE2_URL[0]=ftp://ftp.intevation.de/boss/src/$MODULE
  SOURCE3_URL[0]=ftp://ftp.intevation.de/boss/src/$MODULE
  SOURCE4_URL[0]=ftp://ftp.intevation.de/boss/src/$MODULE
   SOURCE_URL[1]=ftp://ftp.nessus.org/pub/nessus/$MODULE-$VERSION/src/
  SOURCE2_URL[1]=ftp://ftp.nessus.org/pub/nessus/$MODULE-$VERSION/src/
  SOURCE3_URL[1]=ftp://ftp.nessus.org/pub/nessus/$MODULE-$VERSION/src/
  SOURCE4_URL[1]=ftp://ftp.nessus.org/pub/nessus/$MODULE-$VERSION/src/
        WEB_SITE=http://www.nessus.org/
         ENTERED=20021013
         UPDATED=20200526
           SHORT="A security scanner"
           PSAFE=no

cat << EOF
Nessus is a security scanner.
The "Nessus" Project aims to provide to the internet community a free, powerful,
up-to-date and easy to use remote security scanner.
A security scanner is a software which will audit remotely a given network and
determine whether bad guys (aka "crackers") may break into it, or misuse it in
some way.
EOF
