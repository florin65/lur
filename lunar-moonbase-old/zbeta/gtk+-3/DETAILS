          MODULE=gtk\+-3
           MAJOR=3.4
         VERSION=4.3
          SOURCE=$MODULE.$VERSION.tar.xz
SOURCE_DIRECTORY=$BUILD_DIRECTORY/$MODULE.$VERSION
      SOURCE_URL=$GNOME_URL/sources/gtk+/$MAJOR
      SOURCE_VFY=sha1:645150ddc417b7bd109b956beeebcccf94a50f24
        WEB_SITE=http://www.gtk.org
         ENTERED=20020313
         UPDATED=20120513
           SHORT="A multi-platform toolkit for creating GUIs"

cat << EOF
GTK+-3 is a multi-platform toolkit for creating graphical user
interfaces. Offering a complete set of widgets, GTK+-3 is suitable
for projects ranging from small one-off projects to complete
application suites.

GTK+-3 should be parallel installable along with gtk+-2.
EOF
